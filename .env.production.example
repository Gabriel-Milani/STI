FLASK_ENV=production
SECRET_KEY=gere-uma-chave-longa-e-aleatoria
DATABASE_PATH=data/estoque_v2.db
APP_BASE_URL=https://estoque-ti.exemplo.local
ADMIN_INITIAL_PASSWORD=defina-uma-senha-forte-no-primeiro-deploy

SESSION_COOKIE_SAMESITE=Lax
SESSION_COOKIE_SECURE=1
MAX_CONTENT_LENGTH=8388608

DB_BACKUP_ON_START=0
DB_BACKUP_DIR=backups
DB_BACKUP_RETENTION=30

LOG_LEVEL=INFO
LOG_FILE=logs/estoque-ti.log
LOG_MAX_BYTES=2000000
LOG_BACKUP_COUNT=10

HOST=0.0.0.0
PORT=5000
WAITRESS_THREADS=8
